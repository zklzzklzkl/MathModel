# MathModelAgent local environment template
#
# Put this file at either:
# - app/backend/.env  (preferred for the local backend), or
# - .env              (repo-root fallback, also supported)
#
# provider=none does not need any API key.
# Do not paste API keys into the browser frontend.

# Workspace roots
MATHMODEL_ROOT=
MATHMODEL_WORKSPACE_ROOT=workspaces
WORKSPACE_ROOT=
EXAMPLES_ROOT=

# Runtime provider
# none | deepseek | openai-compatible
MATHMODEL_LLM_PROVIDER=none

# Generic OpenAI-compatible variables read by the backend
MATHMODEL_LLM_API_KEY=
MATHMODEL_LLM_BASE_URL=
MATHMODEL_LLM_MODEL=
MATHMODEL_LLM_TEMPERATURE=0.2
MATHMODEL_LLM_MAX_TOKENS=4096

# DeepSeek aliases are also accepted when provider=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible aliases are also accepted when provider=openai-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

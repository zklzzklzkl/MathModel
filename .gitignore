# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# LaTeX / Typst build artifacts
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.fls
*.fdb_latexmk
*.bbl
*.blg
*.bcf
*.run.xml

# OS files
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Example workspace outputs (keep source, ignore generated)
examples/*/paper/*.aux
examples/*/paper/*.log
examples/*/paper/*.out
examples/*/paper/*.toc
examples/*/code/__pycache__/
examples/*/results/
examples/*/_monitor/

# Temporary files
*.tmp
*.temp
_monitor/

# Example workspace generated outputs
examples/*/code/outputs/
examples/*/paper/*.pdf
examples/*/results/

# Local config (do not commit)
.obsidian/
.claudian/
*.zip

# Control Center local runtime data (do not commit)
workspaces/
examples/**/source/
examples/**/runs/
**/control-center-history.jsonl
app/backend/.env
app/backend/.venv/
app/frontend/node_modules/
app/frontend/dist/
